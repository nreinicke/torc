#!/bin/sh
#
# Pre-commit hook for torc project
# Runs Rust formatting, linting, markdown formatting, and shell script linting
#

set -e

echo '+cargo fmt -- --check'
cargo fmt -- --check

echo '+cargo clippy --all --all-targets --all-features -- -D warnings'
cargo clippy --all --all-targets --all-features -- -D warnings

echo '+dprint check'
dprint check

# Lint shell scripts if shellcheck is available
if command -v shellcheck >/dev/null 2>&1; then
  echo '+shellcheck (all .sh files)'
  find . -name '*.sh' -not -path './target/*' -not -path './.venv/*' -not -path '*/\.venv/*' -type f -exec shellcheck {} +
else
  echo 'shellcheck not found, skipping shell script linting'
fi
